<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <!-- Default burn-face color (RGB). Overridable per run. -->
    <add key="DefaultBurnColorR" value="255" />
    <add key="DefaultBurnColorG" value="0" />
    <add key="DefaultBurnColorB" value="0" />
    <!-- Color match tolerance per channel (0-255). -->
    <add key="ColorTolerancePerChannel" value="8" />
  </appSettings>
</configuration>
